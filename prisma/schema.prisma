generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model SystemSettings {
  id                   String   @id @default(cuid())
  geminiApiKey         String?
  defaultAttendeeTypes String[] @default([])
  defaultMeetingTypes  String[] @default([])
  defaultTags          String[] @default([])
  defaultRegionTypes   String[] @default([])
  defaultContentTypes  String[] @default([])
  contentTypeColors    Json?
  maintenanceMode      Boolean  @default(false)
  brandVoice           String?  @db.Text // Rakuten Symphony brand voice/tone spec, injected into content-draft prompts
}

model Event {
  id              String     @id @default(cuid())
  name            String     @unique
  startDate       DateTime?
  endDate         DateTime?
  tags            String[]   @default([])
  meetingTypes    String[]   @default([])
  attendeeTypes   String[]   @default([])
  authorizedUserIds String[] @default([])
  timezone        String?
  boothLocation   String?
  url             String?
  address         String?
  requesterEmail  String?
  region          String?
  budget          Float?
  targetCustomers String?
  status          String     @default("PIPELINE")
  slug              String     @unique
  attendees         Attendee[]
  meetings          Meeting[]
  rooms             Room[]
  roiTargets        EventROITargets?
  marketingChecklist EventMarketingChecklist?
  password          String?
  description       String?
  latitude          Float?
  longitude         Float?
  subscriptionCount Int        @default(0)
  intelligenceSubs  IntelligenceSubEvent[]
  linkedInDrafts    LinkedInDraft[]
  attendeeReports   AttendeeEventReport[]
  pitches           Pitch[]
  contentTasks      ContentTask[]
  campaignProposals CampaignProposal[]
}

model Company {
  id              String            @id @default(cuid())
  name            String            @unique
  description     String?
  pipelineValue   Float?
  region          String?
  subscribed      Boolean           @default(false)
  attendees         Attendee[]
  targetedByROI     EventROITargets[] @relation("TargetCompanies")
  subscriptionCount Int               @default(0)
  intelligenceSubs  IntelligenceSubCompany[]
}

model Attendee {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  bio            String?
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id])
  linkedin       String?
  imageUrl       String?
  title          String
  isExternal     Boolean   @default(false)
  emailMissing   Boolean   @default(false)
  type           String?
  seniorityLevel String?
  events            Event[]
  meetings          Meeting[]  @relation("AttendeeMeetings")
  subscriptionCount Int        @default(0)
  intelligenceSubs  IntelligenceSubAttendee[]
  eventReports      AttendeeEventReport[]
  pitchTargets      PitchAttendee[]
}

model Room {
  id       String    @id @default(cuid())
  name     String
  capacity Int
  eventId  String?
  meetings Meeting[]
  event    Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([name, eventId])
}

model Meeting {
  id                 String        @id @default(cuid())
  title              String
  purpose            String?
  startTime          String?
  endTime            String?
  roomId             String?
  sequence           Int           @default(0)
  status             MeetingStatus @default(PIPELINE)
  tags               String[]      @default([])
  date               String?
  calendarInviteSent Boolean       @default(false)
  createdBy          String?
  isApproved         Boolean       @default(false)
  meetingType        String?
  otherDetails       String?
  requesterEmail     String?
  location           String?
  eventId            String?
  pitchId            String?
  event              Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  room               Room?         @relation(fields: [roomId], references: [id])
  attendees          Attendee[]    @relation("AttendeeMeetings")
  pitch              Pitch?        @relation(fields: [pitchId], references: [id], onDelete: SetNull)

  @@index([pitchId])
}

enum MeetingStatus {
  PIPELINE
  CONFIRMED
  OCCURRED
  CANCELED
}

model ContentTask {
  id              String            @id @default(cuid())
  title           String
  description     String?           @db.Text
  notes           String?           @db.Text
  contentType     String?
  status          ContentTaskStatus @default(TODO)
  dueDate         DateTime?
  tags            String[]          @default([])
  assigneeId      String?
  collaboratorIds String[]          @default([])
  eventId         String?
  createdBy       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  event           Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  attachments     ContentTaskAttachment[]

  @@index([eventId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
}

model ContentTaskAttachment {
  id            String      @id @default(cuid())
  contentTaskId String
  task          ContentTask @relation(fields: [contentTaskId], references: [id], onDelete: Cascade)
  title         String
  fileUrl       String
  originalName  String
  createdAt     DateTime    @default(now())

  @@index([contentTaskId])
}

enum ContentTaskStatus {
  DRAFT
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

// System-level "themes Rakuten Symphony wants to own". Single living doc (one row),
// edited by root/marketing and ingested by the marketing agent.
model MarketingStrategy {
  id        String   @id @default(cuid())
  themes    Json     @default("[]") // [{ name, description, priority }]
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Agent-generated marketing campaign proposal. Planning layer: on activation it
// spawns ContentTask(s) and (when an event is set) LinkedInDraft(s) for execution.
// Idempotent on (runId, theme) so the agent can re-POST without duplicating.
model CampaignProposal {
  id                        String    @id @default(cuid())
  runId                     String
  theme                     String
  title                     String
  rationale                 String    @db.Text
  proposalContent           String    @db.Text
  status                    String    @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | ACTIVATED | REJECTED
  eventId                   String?
  event                     Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdBy                 String?
  reviewedBy                String?
  reviewedAt                DateTime?
  rejectedReason            String?
  activatedBy               String?
  activatedAt               DateTime?
  reusedAssets              Json? // [{ kind, id?, url?, title? }] existing content the agent reused
  suggestedContentTasks     Json? // [{ title, description?, contentType?, tags? }] materialized on activate
  suggestedLinkedInArticles Json? // [{ title, content, angle, tone, articleType? }] materialized on activate (needs eventId)
  generatedContentTaskIds   String[]  @default([])
  generatedLinkedInDraftIds String[]  @default([])
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@unique([runId, theme])
  @@index([status])
  @@index([eventId])
}

// On-demand "Generate Campaign" job queue. The browser enqueues a PENDING request
// (one theme); the sales-recon marketing-runner.py polls, runs the agent, and marks
// it DONE/FAILED. Phase-3 cron enqueues one request per theme using the same runner.
model CampaignRunRequest {
  id          String    @id @default(cuid())
  theme       String
  status      String    @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  requestedBy String?
  requestedAt DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  runId       String?
  proposalId  String?
  error       String?   @db.Text

  @@index([status])
}

model EventROITargets {
  id                      String    @id @default(cuid())
  eventId                 String    @unique
  event                   Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Financials
  expectedPipeline        Float?
  winRate                 Float?
  expectedRevenue         Float?

  // Meeting KPIs
  targetCustomerMeetings  Int?

  // Engagement
  targetErta              Float?
  targetSpeaking          Int?
  targetMediaPR           Int?
  targetEventScans        Int?

  // Marketing Plan (generated by AI, editable by user)
  marketingPlan           String?

  // Target Companies
  targetCompanies         Company[] @relation("TargetCompanies")

  // Actuals (manually entered)
  actualErta              Float?
  actualSpeaking          Int?
  actualMediaPR           Int?
  actualEventScans        Int?
  actualCost              Float?

  // Approval
  status                  String   @default("DRAFT")
  approvedBy              String?
  approvedAt              DateTime?
  submittedAt             DateTime?
  rejectedBy              String?
  rejectedAt              DateTime?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model IntelligenceSubscription {
  id                  String   @id @default(cuid())
  userId              String   @unique
  email               String
  active              Boolean  @default(true)
  unsubscribeToken    String   @unique @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  selectedAttendees   IntelligenceSubAttendee[]
  selectedCompanies   IntelligenceSubCompany[]
  selectedEvents      IntelligenceSubEvent[]
}

model IntelligenceReport {
  id                String   @id @default(cuid())
  runId             String
  targetType        String
  targetName        String
  summary           String
  salesAngle        String
  fullReport        String
  recommendedAction String?
  createdAt         DateTime @default(now())

  @@unique([runId, targetName])
  @@index([runId])
  @@index([targetName])
}

model IntelligenceEmailLog {
  id          String   @id @default(cuid())
  runId       String
  userId      String
  email       String
  sentAt      DateTime @default(now())
  targetCount Int
  status      String
  region      String?

  @@unique([runId, userId, status, region])
  @@index([runId, userId])
}

model LinkedInDraft {
  id             String    @id @default(cuid())
  eventId        String
  companyIds     String[]
  companyNames   String[]
  title          String?
  content        String    @db.Text
  originalContent String?  @db.Text
  angle          String
  tone           String
  articleType    String?
  status         String    @default("DRAFT")
  createdBy      String
  createdAt      DateTime  @default(now())

  adStartDate              DateTime?
  adEndDate                DateTime?
  ctaUrl                   String?
  impressions              Int?
  clicks                   Int?
  averageCtr               Float?
  averageCpc               Float?
  topCompaniesByEngagement       String?   @db.Text
  budget                         Float?
  activeUsers                    Int?
  viewsPerUser                   Float?
  avgEngagementTimePerActiveUser Float?

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdBy])
}

model IntelligenceSubAttendee {
  subscriptionId String
  attendeeId     String
  subscription   IntelligenceSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  attendee       Attendee                 @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  @@id([subscriptionId, attendeeId])
  @@index([attendeeId])
}

model IntelligenceSubCompany {
  subscriptionId String
  companyId      String
  subscription   IntelligenceSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@id([subscriptionId, companyId])
  @@index([companyId])
}

model IntelligenceSubEvent {
  subscriptionId String
  eventId        String
  subscription   IntelligenceSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@id([subscriptionId, eventId])
  @@index([eventId])
}

model EventMarketingChecklist {
  id                    String   @id @default(cuid())
  eventId               String   @unique
  event                 Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Pre-Event (7 items)
  eventRecommendation   Boolean  @default(false)
  eventROICompleted     Boolean  @default(false)
  approval              Boolean  @default(false)
  eventPlanning         Boolean  @default(false)
  campaignPlanning      Boolean  @default(false)
  campaignActivation    Boolean  @default(false)
  campaignEvaluation    Boolean  @default(false)

  // During-Event (3 items)
  internalAttendeesAdded Boolean @default(false)
  liveCoverage          Boolean  @default(false)
  leadManagement        Boolean  @default(false)

  // Post-Event (7 items)
  eventDataCapture      Boolean  @default(false)
  eventWrapUp           Boolean  @default(false)
  contentAmplification  Boolean  @default(false)
  crmUpdate             Boolean  @default(false)
  reportingActivations  Boolean  @default(false)
  debriefOnTeamMeeting  Boolean  @default(false)
  eventCompleted        Boolean  @default(false)

  // Notes (JSON map of checkboxKey → string)
  notes                 Json?

  // Final Report
  finalReport           String?  @db.Text

  // Next Year Decision
  nextYearDecision      String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AttendeeEventReport {
  eventId    String
  attendeeId String
  reportText String   @db.Text
  updatedAt  DateTime @updatedAt

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@id([eventId, attendeeId])
  @@index([attendeeId])
}

model Pitch {
  id        String   @id @default(cuid())
  title     String
  pitchText String   @db.Text
  tags      String[] @default([])
  createdBy String?
  createdAt DateTime @default(now())
  modified  DateTime @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  sourcePitchId String?
  sourcePitch   Pitch?  @relation("PitchLineage", fields: [sourcePitchId], references: [id], onDelete: SetNull)
  copies        Pitch[] @relation("PitchLineage")

  targets  PitchAttendee[]
  meetings Meeting[]

  @@index([eventId])
  @@index([sourcePitchId])
}

model PitchAttendee {
  pitchId         String
  attendeeId      String
  resultingUrls   String?  @db.Text
  additionalNotes String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pitch    Pitch    @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  attendee Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@id([pitchId, attendeeId])
  @@index([attendeeId])
}

model AILog {
  id           String   @id @default(cuid())
  userEmail    String
  functionName String
  prompt       String   @db.Text
  modelUsed    String
  createdAt    DateTime @default(now())

  @@index([userEmail])
  @@index([functionName])
}

model ViberLinkCode {
  code        String    @id
  clerkUserId String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([clerkUserId])
  @@index([expiresAt])
}

model ViberUser {
  viberUserId String   @id
  clerkUserId String   @unique
  viberName   String
  linkedAt    DateTime @default(now())
}

model UserProfile {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  regions     String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([regions], type: Gin)
}
