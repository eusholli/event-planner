generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model SystemSettings {
  id                   String   @id @default(cuid())
  geminiApiKey         String?
  defaultAttendeeTypes String[] @default([])
  defaultMeetingTypes  String[] @default([])
  defaultTags          String[] @default([])
}

model Event {
  id              String     @id @default(cuid())
  name            String     @unique
  startDate       DateTime?
  endDate         DateTime?
  tags            String[]   @default([])
  meetingTypes    String[]   @default([])
  attendeeTypes   String[]   @default([])
  authorizedUserIds String[] @default([])
  timezone        String?
  boothLocation   String?
  url             String?
  address         String?
  requesterEmail  String?
  region          String?
  budget          Float?
  targetCustomers String?
  status          String     @default("PIPELINE")
  slug              String     @unique
  attendees         Attendee[]
  meetings          Meeting[]
  rooms             Room[]
  roiTargets        EventROITargets?
  marketingChecklist EventMarketingChecklist?
  password          String?
  description       String?
  latitude          Float?
  longitude         Float?
  subscriptionCount Int        @default(0)
  intelligenceSubs  IntelligenceSubEvent[]
  linkedInDrafts    LinkedInDraft[]
}

model Company {
  id              String            @id @default(cuid())
  name            String            @unique
  description     String?
  pipelineValue   Float?
  attendees         Attendee[]
  targetedByROI     EventROITargets[] @relation("TargetCompanies")
  subscriptionCount Int               @default(0)
  intelligenceSubs  IntelligenceSubCompany[]
}

model Attendee {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  bio            String?
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id])
  linkedin       String?
  imageUrl       String?
  title          String
  isExternal     Boolean   @default(false)
  emailMissing   Boolean   @default(false)
  type           String?
  seniorityLevel String?
  events            Event[]
  meetings          Meeting[]  @relation("AttendeeMeetings")
  subscriptionCount Int        @default(0)
  intelligenceSubs  IntelligenceSubAttendee[]
}

model Room {
  id       String    @id @default(cuid())
  name     String
  capacity Int
  eventId  String?
  meetings Meeting[]
  event    Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([name, eventId])
}

model Meeting {
  id                 String        @id @default(cuid())
  title              String
  purpose            String?
  startTime          String?
  endTime            String?
  roomId             String?
  sequence           Int           @default(0)
  status             MeetingStatus @default(PIPELINE)
  tags               String[]      @default([])
  date               String?
  calendarInviteSent Boolean       @default(false)
  createdBy          String?
  isApproved         Boolean       @default(false)
  meetingType        String?
  otherDetails       String?
  requesterEmail     String?
  location           String?
  eventId            String?
  event              Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  room               Room?         @relation(fields: [roomId], references: [id])
  attendees          Attendee[]    @relation("AttendeeMeetings")
}

enum MeetingStatus {
  PIPELINE
  CONFIRMED
  OCCURRED
  CANCELED
}

model EventROITargets {
  id                      String    @id @default(cuid())
  eventId                 String    @unique
  event                   Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Financials
  expectedPipeline        Float?
  winRate                 Float?
  expectedRevenue         Float?

  // Meeting KPIs
  targetCustomerMeetings  Int?

  // Engagement
  targetErta              Float?
  targetSpeaking          Int?
  targetMediaPR           Int?

  // Marketing Plan (generated by AI, editable by user)
  marketingPlan           String?

  // Target Companies
  targetCompanies         Company[] @relation("TargetCompanies")

  // Actuals (manually entered)
  actualErta              Float?
  actualSpeaking          Int?
  actualMediaPR           Int?
  actualCost              Float?

  // Approval
  status                  String   @default("DRAFT")
  approvedBy              String?
  approvedAt              DateTime?
  submittedAt             DateTime?
  rejectedBy              String?
  rejectedAt              DateTime?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model IntelligenceSubscription {
  id                  String   @id @default(cuid())
  userId              String   @unique
  email               String
  active              Boolean  @default(true)
  unsubscribeToken    String   @unique @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  selectedAttendees   IntelligenceSubAttendee[]
  selectedCompanies   IntelligenceSubCompany[]
  selectedEvents      IntelligenceSubEvent[]
}

model IntelligenceReport {
  id                String   @id @default(cuid())
  runId             String
  targetType        String
  targetName        String
  summary           String
  salesAngle        String
  fullReport        String
  recommendedAction String?
  createdAt         DateTime @default(now())

  @@unique([runId, targetName])
  @@index([runId])
  @@index([targetName])
}

model IntelligenceEmailLog {
  id          String   @id @default(cuid())
  runId       String
  userId      String
  email       String
  sentAt      DateTime @default(now())
  targetCount Int
  status      String

  @@index([runId, userId])
}

model LinkedInDraft {
  id             String    @id @default(cuid())
  eventId        String
  companyIds     String[]
  companyNames   String[]
  title          String?
  content        String    @db.Text
  originalContent String?  @db.Text
  angle          String
  tone           String
  articleType    String?
  status         String    @default("DRAFT")
  createdBy      String
  createdAt      DateTime  @default(now())

  adStartDate              DateTime?
  adEndDate                DateTime?
  ctaUrl                   String?
  impressions              Int?
  clicks                   Int?
  averageCtr               Float?
  averageCpc               Float?
  topCompaniesByEngagement String?   @db.Text

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdBy])
}

model IntelligenceSubAttendee {
  subscriptionId String
  attendeeId     String
  subscription   IntelligenceSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  attendee       Attendee                 @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  @@id([subscriptionId, attendeeId])
  @@index([attendeeId])
}

model IntelligenceSubCompany {
  subscriptionId String
  companyId      String
  subscription   IntelligenceSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@id([subscriptionId, companyId])
  @@index([companyId])
}

model IntelligenceSubEvent {
  subscriptionId String
  eventId        String
  subscription   IntelligenceSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@id([subscriptionId, eventId])
  @@index([eventId])
}

model EventMarketingChecklist {
  id                    String   @id @default(cuid())
  eventId               String   @unique
  event                 Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Pre-Event (7 items)
  eventRecommendation   Boolean  @default(false)
  eventROICompleted     Boolean  @default(false)
  approval              Boolean  @default(false)
  eventPlanning         Boolean  @default(false)
  campaignPlanning      Boolean  @default(false)
  campaignActivation    Boolean  @default(false)
  campaignEvaluation    Boolean  @default(false)

  // During-Event (3 items)
  internalAttendeesAdded Boolean @default(false)
  liveCoverage          Boolean  @default(false)
  leadManagement        Boolean  @default(false)

  // Post-Event (7 items)
  eventDataCapture      Boolean  @default(false)
  eventWrapUp           Boolean  @default(false)
  contentAmplification  Boolean  @default(false)
  crmUpdate             Boolean  @default(false)
  reportingActivations  Boolean  @default(false)
  debriefOnTeamMeeting  Boolean  @default(false)
  eventCompleted        Boolean  @default(false)

  // Notes (JSON map of checkboxKey → string)
  notes                 Json?

  // Final Report
  finalReport           String?  @db.Text

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AILog {
  id           String   @id @default(cuid())
  userEmail    String
  functionName String
  prompt       String   @db.Text
  modelUsed    String
  createdAt    DateTime @default(now())

  @@index([userEmail])
  @@index([functionName])
}
